# Credenciales de la base de datos PostgreSQL
DB_PASSWORD=cambia_esta_contraseña
DB_USER=LTIdbUser
DB_NAME=LTIdb
DB_PORT=5434

# Cadena de conexión usada por Prisma (se expande con las variables de arriba)
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}"

# Claves de Datadog para Terraform (Organization Settings > API/Application Keys)
TF_VAR_datadog_api_key="tu_api_key_de_datadog"
TF_VAR_datadog_app_key="tu_app_key_de_datadog"
